BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321
PUBLISH_CHANNEL_ID=@your_channel_username

# Optional HTTP API. Disabled by default.
HTTP_API_ENABLED=false
HTTP_API_HOST=0.0.0.0
HTTP_API_PORT=8080
POST_TOKEN=replace_with_a_random_api_token

# Optional R-18 routing. Pixiv uses metadata only; X/Twitter checks at most 4 images; Poipiku checks all images.
R18_ROUTING_ENABLED=false
R18_CHANNEL_ID=@your_r18_channel
NSFW_DETECTION_ENABLED=false
NSFW_HIGH_THRESHOLD=0.80
NSFW_LOW_THRESHOLD=0.25
NSFW_TWITTER_MAX_IMAGES=4

# Optional paths.
DATA_DIR=./data
DATABASE_PATH=./data/db.sqlite
MEDIA_DIR=./data/media
TEMP_DIR=./data/tmp

# Optional unified bookmark monitor. `/bookmark_watch` and HTTP `/bookmarks/start`
# activate every configured source together.
BOOKMARKS_ENABLED=false

# X/Twitter requires an OAuth 2.0 user access token with bookmark.read, tweet.read, and users.read scopes.
TWITTER_BOOKMARKS_ENABLED=false
TWITTER_BOOKMARKS_USER_ID=your_x_user_id
TWITTER_BOOKMARKS_ACCESS_TOKEN=your_oauth2_user_access_token
TWITTER_BOOKMARKS_REFRESH_TOKEN=your_oauth2_refresh_token
TWITTER_OAUTH_CLIENT_ID=your_oauth2_client_id
TWITTER_OAUTH_CLIENT_SECRET=your_oauth2_client_secret
TWITTER_BOOKMARKS_POLL_SECONDS=30
TWITTER_BOOKMARKS_GRACE_SECONDS=10
TWITTER_BOOKMARKS_IDLE_SECONDS=300
TWITTER_BOOKMARKS_MAX_RESULTS=10

# Pixiv bookmark polling uses a Netscape cookies file plus your Pixiv user id.
PIXIV_BOOKMARKS_USER_ID=your_pixiv_user_id
PIXIV_BOOKMARKS_COOKIES=./secrets/pixiv-cookies.txt

# Poipiku bookmark polling uses a Netscape cookies file.
# It defaults to `GALLERY_DL_COOKIES` when omitted.
POIPIKU_BOOKMARKS_COOKIES=./secrets/poipiku-cookies.txt
WEB_BOOKMARKS_MAX_RESULTS=20
WEB_BOOKMARKS_MAX_PAGES=4
